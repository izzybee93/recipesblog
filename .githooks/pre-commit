#!/bin/sh

# Process recipe files and images before commit

# Process recipe MDX files - replace fractions with Unicode characters
echo "📝 Processing recipe files..."

RECIPES=$(git diff --cached --name-only --diff-filter=ACM | grep "^content/recipes/.*\.mdx$")

if [ ! -z "$RECIPES" ]; then
  for RECIPE in $RECIPES; do
    echo "Processing fractions in: $RECIPE"
    
    # Replace common fractions with Unicode equivalents and add degree symbols
    # Using sed with in-place editing
    sed -i '' \
      -e 's/1\/4/¼/g' \
      -e 's/1\/2/½/g' \
      -e 's/3\/4/¾/g' \
      -e 's/1\/3/⅓/g' \
      -e 's/2\/3/⅔/g' \
      -e 's/1\/8/⅛/g' \
      -e 's/3\/8/⅜/g' \
      -e 's/5\/8/⅝/g' \
      -e 's/7\/8/⅞/g' \
      -e 's/1\/5/⅕/g' \
      -e 's/2\/5/⅖/g' \
      -e 's/3\/5/⅗/g' \
      -e 's/4\/5/⅘/g' \
      -e 's/1\/6/⅙/g' \
      -e 's/5\/6/⅚/g' \
      -e 's/\([0-9]\{1,3\}\)C/\1°C/g' \
      -e 's/\([0-9]\{1,3\}\)F/\1°F/g' \
      "$RECIPE"
    
    # Re-add the processed file to git
    git add "$RECIPE"
  done
  echo "✅ Recipe fractions converted successfully!"

  # Alphabetize categories in recipe frontmatter
  for RECIPE in $RECIPES; do
    # Handle YAML list format (categories:\n  - a\n  - b)
    CATS=$(sed -n '/^categories:$/,/^[^ ]/{ /^  - /p; }' "$RECIPE")
    if [ ! -z "$CATS" ]; then
      CAT_COUNT=$(echo "$CATS" | wc -l | tr -d ' ')
      if [ "$CAT_COUNT" -ge 2 ]; then
        SORTED=$(echo "$CATS" | sort)
        if [ "$CATS" != "$SORTED" ]; then
          echo "Alphabetizing categories in: $RECIPE"
          SORTED_LINES=$(echo "$SORTED" | tr '\n' '|' | sed 's/|$//')
          awk -v sorted="$SORTED_LINES" '
            /^categories:$/ { print; in_cats=1; next }
            in_cats && /^  - / { next }
            in_cats {
              n = split(sorted, arr, "|")
              for (i=1; i<=n; i++) print arr[i]
              in_cats=0
            }
            { print }
          ' "$RECIPE" > "${RECIPE}.tmp" && mv "${RECIPE}.tmp" "$RECIPE"
          git add "$RECIPE"
        fi
      fi
      continue
    fi

    # Handle inline array format (categories: ["a", "b"])
    INLINE=$(grep '^categories: \[' "$RECIPE")
    if [ ! -z "$INLINE" ]; then
      # Extract category names, sort, and rebuild
      SORTED_LINE=$(echo "$INLINE" | sed 's/categories: \[//;s/\]//' | tr ',' '\n' | sed 's/^ *//;s/ *$//;s/"//g' | sort | awk '{printf "\"%s\", ", $0}' | sed 's/, $//')
      NEW_LINE="categories: [$SORTED_LINE]"
      if [ "$INLINE" != "$NEW_LINE" ]; then
        echo "Alphabetizing categories in: $RECIPE"
        sed -i '' "s|^categories: \[.*\]$|$NEW_LINE|" "$RECIPE"
        git add "$RECIPE"
      fi
    fi
  done
  echo "✅ Recipe categories alphabetized!"
fi

# Process recipe images - strip metadata and resize if needed
echo "🖼️ Processing recipe images..."

IMAGES=$(git diff --cached --name-only --diff-filter=ACM | grep "^public/images/recipes/.*\.\(jpg\|jpeg\|png\)$")

if [ ! -z "$IMAGES" ]; then
  for IMAGE in $IMAGES; do
    echo "Processing: $IMAGE"

    # Strip metadata using exiftool (same as your chop command)
    exiftool "-gps*=" "$IMAGE" -overwrite_original 2>/dev/null

    # Check size and resize if needed
    SIZE=$(stat -f%z "$IMAGE" 2>/dev/null || stat -c%s "$IMAGE" 2>/dev/null)
    if [ "$SIZE" -gt 1048576 ]; then
      ORIGINAL_SIZE=$(ls -lh "$IMAGE" | awk '{print $5}')
      echo "⚠️  Image is $ORIGINAL_SIZE, resizing to be under 1MB..."

      # Check if ImageMagick is installed
      if ! command -v magick &> /dev/null; then
        echo "❌ Error: ImageMagick (magick command) is not installed."
        echo "   Please install ImageMagick: brew install imagemagick"
        exit 1
      fi

      # Keep resizing by 50% until under 1MB
      while true; do
        SIZE=$(stat -f%z "$IMAGE" 2>/dev/null || stat -c%s "$IMAGE" 2>/dev/null)
        if [ "$SIZE" -le 1048576 ]; then
          break
        fi
        magick "$IMAGE" -resize 50% "$IMAGE"
      done

      NEW_SIZE=$(ls -lh "$IMAGE" | awk '{print $5}')
      echo "   ✅ Resized to: $NEW_SIZE"
    fi

    # Re-add the processed file to git
    git add "$IMAGE"
  done
  echo "✅ Recipe images processed successfully!"

  # Regenerate blur placeholders for new/changed images
  echo ""
  echo "🔮 Generating blur placeholders..."
  npm run generate-blur --silent

  if [ $? -eq 0 ]; then
    git add blur-data.json
    echo "✅ Blur data updated"
  else
    echo "⚠️  Warning: Blur data generation failed"
    echo "   Run manually: npm run generate-blur"
  fi
fi

# Upload recipe images to Vercel Blob Storage
echo ""
echo "☁️  Uploading recipe images to Blob Storage..."

# Check if there are any recipe images to upload
if [ -d "public/images/recipes" ]; then
  IMAGE_COUNT=$(find public/images/recipes -type f \( -name "*.jpg" -o -name "*.jpeg" -o -name "*.png" -o -name "*.webp" \) 2>/dev/null | wc -l | tr -d ' ')

  if [ "$IMAGE_COUNT" -gt 0 ]; then
    # Load BLOB_READ_WRITE_TOKEN from .env.local (secure - not hardcoded!)
    if [ -f ".env.local" ]; then
      export $(grep "^BLOB_READ_WRITE_TOKEN=" .env.local | xargs)
    fi

    # Check if token is available
    if [ -z "$BLOB_READ_WRITE_TOKEN" ]; then
      echo "⚠️  Warning: BLOB_READ_WRITE_TOKEN not found in .env.local"
      echo "   Recipe images will not be uploaded to Blob Storage"
      echo "   Run manually: npm run upload-recipe-images"
      echo ""
    else
      # Run upload script
      echo "   Found $IMAGE_COUNT local recipe images"
      npm run upload-recipe-images --silent

      if [ $? -eq 0 ]; then
        echo "✅ Recipe images uploaded to Blob Storage"
      else
        echo "⚠️  Warning: Some images may not have uploaded"
        echo "   Check output above for details"
      fi
    fi
  else
    echo "   No recipe images found to upload"
  fi
else
  echo "   Recipe images directory not found"
fi

# Sync images to GitHub Pages backup repository
echo "🔄 Syncing to backup image repository..."
./scripts/sync-backup-images.sh

echo ""
exit 0